# Sirdaryo KPI — Sozlamalar
# Bu faylni `.env` nomi bilan nusxalang va qiymatlarni to'ldiring

# JWT Secret tokeni — ALBATTA o'zgartiring!
# Quyidagi buyruq bilan yarating: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=BU_YERNI_OZGARTIRING_64_BELGILI_TASODIFIY_STRING

# Telegram bot tokenini @BotFather dan oling va shu yerga yozing
TELEGRAM_BOT_TOKEN=
# Admin Telegram chat ID — @userinfobot dan oling
TELEGRAM_CHAT_ID=

# Server port
PORT=4001

# CORS — production serverda frontend domenini yozing
# Masalan: CORS_ORIGIN=https://kpi.sirdaryo.uz
CORS_ORIGIN=*

# Muhit: development yoki production
NODE_ENV=development
